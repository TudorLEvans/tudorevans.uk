---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tudor Evans">
	<div class="container">
		<section class="hero">
			<span class="hero-eyebrow">Software Engineer &amp; Engineering Manager</span>
			<h1>Tudor Evans</h1>
			<p class="hero-desc">
				I'm a software engineer and engineering manager working on web technologies.
				I have a particular interest in the intersection between tech and commercial orgs.	
			</p>
			<div class="hero-actions">
				<a href="/about" class="btn btn-primary">about me</a>
				<a href="/cv" class="btn btn-outline">curriculum vitae</a>
			</div>
		</section>

		<section class="section tight">
			<p class="section-title">more links</p>
			<ul class="nav-list">
				<li><a href="/blog">Blog</a></li>
				<li><a href="/projects">Side projects</a></li>
				<li><a href="/management-principles">Management principles</a></li>
				<li><a href="https://thetudor.substack.com" target="_blank" rel="noopener">Substack</a></li>
				<li><a href="/interesting-links">Interesting links</a></li>
				<li><a href="/music">Music</a></li>
				<li><a href="/date-me">Date me</a></li>
			</ul>
		</section>

		<section class="section tight">
			<p class="section-title">get in touch</p>
			<ul class="nav-list">
				<li><a href="https://github.com/TudorLEvans" target="_blank" rel="noopener">GitHub</a></li>
				<li><a href="https://www.linkedin.com/in/tudor-evans-5a2232151/" target="_blank" rel="noopener">LinkedIn</a></li>
			</ul>
		</section>

		<section class="section tight">
			<p class="section-title">subscribe</p>
			<div class="substack-wrap">
				<iframe src="https://thetudor.substack.com/embed" width="480" height="320" style="border: 1px solid #EEE; background: white" frameborder="0" scrolling="no"></iframe>
			</div>
		</section>
	</div>
</Layout>
