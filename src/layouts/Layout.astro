---
import '../styles/global.css';
export interface Props {
	title: string;
}

const { title } = Astro.props;
const navLinks = [
	{ href: '/about', label: 'about' },
	{ href: '/cv', label: 'cv' },
	{ href: '/management-principles', label: 'principles' },
];
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<div class="container">
				<a href="/" class="site-name">tudor.evans</a>
				<nav aria-label="Main navigation">
					<ul class="site-nav">
						{navLinks.map(({ href, label, external }) => (
							<li><a href={href} {...(external ? { target: '_blank', rel: 'noopener' } : {})}>{label}</a></li>
						))}
					</ul>
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="container">
				<p>&copy; 2026 Tudor Evans</p>
				<div class="footer-links">
					<a href="https://github.com/TudorLEvans" target="_blank" rel="noopener">github</a>
					<a href="https://www.linkedin.com/in/tudor-evans-5a2232151/" target="_blank" rel="noopener">linkedin</a>
					<a href="https://thetudor.substack.com" target="_blank" rel="noopener">substack</a>
				</div>
			</div>
		</footer>
	</body>
</html>
