---
import '../styles/global.css';
export interface Props {
	title: string;
}

const { title } = Astro.props;
const navLinks = [
	{ href: '/about', label: 'about' },
	{ href: '/cv', label: 'cv' },
	{ href: '/blog', label: 'blog' },
];
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<div class="container">
				<a href="/" class="site-name">tudor.evans</a>
				<nav aria-label="Main navigation">
					<ul class="site-nav">
						{navLinks.map(({ href, label, external }) => (
							<li><a href={href} {...(external ? { target: '_blank', rel: 'noopener' } : {})}>{label}</a></li>
						))}
					</ul>
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="container">
				<p>&copy; 2026 Tudor Evans</p>
				<div class="footer-links">
					<a href="https://github.com/TudorLEvans" target="_blank" rel="noopener">github</a>
					<a href="https://www.linkedin.com/in/tudor-evans-5a2232151/" target="_blank" rel="noopener">linkedin</a>
					<a href="https://thetudor.substack.com" target="_blank" rel="noopener">substack</a>
					<button class="spice-btn" id="spice-trigger" aria-label="The spice">&#x2022;</button>
				</div>
			</div>
		</footer>

		<div class="spice-overlay" id="spice-overlay" role="dialog" aria-modal="true">
			<div class="spice-eyes">
				<div class="spice-eye"></div>
				<div class="spice-eye"></div>
			</div>
			<p class="spice-text">The spice must flow</p>
		</div>

		<script>
			const trigger = document.getElementById('spice-trigger');
			const overlay = document.getElementById('spice-overlay');
			trigger?.addEventListener('click', () => overlay?.classList.add('visible'));
			overlay?.addEventListener('click', () => overlay.classList.remove('visible'));
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') overlay?.classList.remove('visible');
			});
		</script>
	</body>
</html>
